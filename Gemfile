source "https://rubygems.org"

gem "jekyll", "~> 4.3"

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end

# Windows / JRuby support
gem "tzinfo", ">= 1", "< 3", platforms: [:mingw, :x64_mingw, :jruby]
gem "tzinfo-data", platforms: [:mingw, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", platforms: [:mingw, :x64_mingw]
